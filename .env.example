# Pillar Press backend — environment variables.
# ALL server-only. Never prefix with NEXT_PUBLIC_. Never expose to the client.

# --- AI: editorial gates, revision, platform generators, weave ---
ANTHROPIC_API_KEY=

# --- Media: Hedra (image / video / avatar) + ElevenLabs (TTS) ---
HEDRA_API_KEY=
ELEVENLABS_API_KEY=

# --- Database (Postgres, Drizzle) ---
DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Google Drive export (server-side OAuth, offline refresh token) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=https://your-app.vercel.app/api/drive/auth/callback

# --- Auth provider (whatever you wire into lib/auth.ts) ---
# e.g. NEXTAUTH_SECRET / CLERK_SECRET_KEY / SUPABASE keys, etc.
