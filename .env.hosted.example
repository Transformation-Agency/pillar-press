# Pillar Press — hosted web environment.
# Use this for an internet-accessible Next.js deployment such as Vercel,
# Render, Fly, Railway, or a VPS running `npm run web:start`.
#
# Server-only values. Never prefix secrets with NEXT_PUBLIC_ unless the browser
# genuinely needs them.

# --- Runtime mode ---
# These values force the legacy hosted Postgres/Supabase route path and prevent
# desktop SQLite/local-storage settings from being used on a public server.
PILLAR_PRESS_RUNTIME=hosted
PILLAR_PRESS_HOSTED_WEB=true
PILLAR_PRESS_LOCAL_FIRST=false
DATA_BACKEND=postgres
STORAGE_PROVIDER=supabase
PILLAR_PRESS_STORAGE=supabase

# --- Hosted database ---
# Run the Drizzle migrations against this database before serving traffic.
DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Supabase Storage + hosted account auth ---
# Storage is used for generated audio/image/video assets that need a public URL.
# Auth uses the public URL + anon key in the browser, and the service-role key
# only on the server to validate sessions and bootstrap workspaces.
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- Public URL protection ---
# Preferred hosted SaaS mode uses Supabase Auth. Hosted mode requires login by
# default if AUTH_DISABLED is omitted; keep AUTH_DISABLED=false here for clarity.
# SITE_PASSWORD is only a temporary/private-preview gate while AUTH_DISABLED=true.
# Leave SITE_USERS blank to allow "king" and legacy "pillar", or set an allow-list.
SITE_USERS=king,pillar
SITE_PASSWORD=

# Set true only for a private shared-workspace preview behind SITE_PASSWORD.
AUTH_DISABLED=false
DEFAULT_USER_ID=web-user

# --- SaaS billing ---
# Stripe Checkout handles paid upgrades. Webhooks keep local workspace
# subscription state in sync. Price ids can be stored in the plans table or set
# here as env fallbacks.
APP_URL=https://your-domain.example
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# --- Hosted secret encryption ---
# Used to encrypt BYOK provider API keys saved from the hosted web app.
# Generate a long random value and keep it stable across deploys.
PILLAR_PRESS_HOSTED_SECRET_KEY=

# --- Hosted support/admin tools ---
# Optional. Enables read-only support diagnostics at /api/admin/support/workspaces.
# Keep this server-only and send it as Bearer auth or x-pillar-press-admin-secret.
PILLAR_PRESS_ADMIN_SECRET=
PILLAR_PRESS_SUPPORT_SECRET=

# --- Hosted background workers ---
# Required for the scheduled worker endpoint that runs queued Gather jobs.
PILLAR_PRESS_JOB_SECRET=

# --- LLM providers ---
# Choose one default provider. Task-level overrides can still be configured with
# LLM_TASK_<TASK>_* variables.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
OPENAI_API_KEY=

# Anthropic compatibility/defaults.
ANTHROPIC_API_KEY=

# Other supported providers.
XAI_API_KEY=
GROK_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
LLM_BASE_URL=
LLM_MAX_TOKENS=32000

# PDF/image extraction fallback. Text and .docx are still decoded locally.
LLM_FILE_PROVIDER=anthropic
LLM_FILE_MODEL=claude-haiku-4-5
LLM_FILE_API_KEY=
LLM_FILE_BASE_URL=

# --- Studio media providers ---
HEDRA_API_KEY=
ELEVENLABS_API_KEY=
MEDIA_OPENAI_API_KEY=
MEDIA_OPENAI_BASE_URL=https://api.openai.com/v1
MEDIA_OPENAI_IMAGE_MODELS=gpt-image-1
MEDIA_OPENAI_AUDIO_MODELS=gpt-4o-mini-tts,tts-1
MEDIA_XAI_API_KEY=
MEDIA_XAI_BASE_URL=https://api.x.ai/v1
MEDIA_XAI_IMAGE_MODELS=grok-2-image
MEDIA_IMAGE_BASE_URL=
MEDIA_IMAGE_API_KEY=
MEDIA_IMAGE_MODELS=

# --- Google Drive export ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=https://your-domain.example/api/drive/auth/callback

# --- Gather research connectors ---
BRAVE_SEARCH_API_KEY=
Brave_Kings_Press=
X_BEARER_TOKEN=
YOUTUBE_API_KEY=
GATHER_CONTACT_EMAIL=
NCBI_API_KEY=
