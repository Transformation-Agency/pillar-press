{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Pillar Press",
  "version": "0.1.0",
  "identifier": "com.pillar.press",
  "build": {
    "beforeDevCommand": "npm run desktop:web",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run desktop:web:build",
    "beforeBundleCommand": "npm run desktop:sign-macos-resources",
    "frontendDist": "../public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Pillar Press",
        "width": 1280,
        "height": 840,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Local-first content generation desk for Pillar Press",
    "longDescription": "Pillar Press is a local-first AI-assisted content generation and editorial operations workstation.",
    "macOS": {
      "signingIdentity": "-"
    },
    "resources": [
      "resources/desktop-server",
      "resources/node",
      "resources/whisper"
    ]
  }
}
